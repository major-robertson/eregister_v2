APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Disk for generated resale certificate PDFs + signature images.
# Defaults to FILESYSTEM_DISK when unset; use s3 in production.
# RESALE_CERT_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# PDF generation (spatie/laravel-pdf). Use the pure-PHP DOMPDF driver so document
# generation needs no Chrome/Node. Other drivers (browsershot) require a headless
# browser; switch only if that infra is available.
LARAVEL_PDF_DRIVER=dompdf

VITE_APP_NAME="${APP_NAME}"

GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=

# Stripe / Laravel Cashier. Set TEST keys here to run real test-mode payments
# locally (same as sales tax / liens). Leave STRIPE_SECRET blank only if you
# want the keyless stub path instead. Stripe Price IDs are NOT env vars — they
# live in the `prices` catalog (database/seeders/*), test + live per row.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

REDDIT_CAPI_TOKEN=
REDDIT_CAPI_ENABLED=false
REDDIT_CAPI_TEST_ID=

OPENAI_ADS_CAPI_TOKEN=
OPENAI_ADS_CAPI_ENABLED=false
OPENAI_ADS_CAPI_VALIDATE_ONLY=false
